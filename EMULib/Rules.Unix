###
### Include this file in the first line of your Makefile when compiling
### EMULib application for generic Unix flavor using SDL2.
###

include ../../EMULib/Rules.gcc

# Common flags
CFLAGS  += -I$(EMULIB)/Unix $(shell pkg-config --cflags sdl2)
DEFINES += -DUNIX -DBPS16 -DSDL2
OBJECTS += $(EMUUNIX)
LIBS    += $(shell pkg-config --libs sdl2)
